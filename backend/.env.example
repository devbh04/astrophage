# Google AI — pick ONE auth method:
# Option A: GCP service account (Vertex AI) — preferred
GCP_CREDENTIALS_PATH=/path/to/your/gcp-service-account.json
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
# Option B: Gemini Developer API key (fallback)
# GOOGLE_API_KEY=your_google_api_key
LLM_MODEL=gemini-3-flash-preview
EMBEDDING_MODEL=gemini-embedding-001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=astrophage_knowledge

# Auth
JWT_SECRET=generate-a-strong-random-secret-here
JWT_EXPIRY_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=7860
